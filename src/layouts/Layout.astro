---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = "技術ブログ", wide = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary_large_image" />

		<link
			rel="alternate"
			type="application/rss+xml"
			title="RSS"
			href="/rss.xml"
		/>
	</head>
	<body>
		<Header />
		<main class:list={{ wide }}>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--color-primary: #2563eb;
		--color-primary-dark: #1d4ed8;
		--color-primary-light: #e7effd;
		--color-accent: #38bdf8;
		--color-accent-dark: #0ea5e9;

		--color-text: #1f2933;
		--color-text-muted: #6b7280;
		--color-heading: #16233a;

		--color-bg: #ffffff;
		--color-bg-subtle: #f5f8fd;
		--color-border: #e3e8f0;

		--radius: 12px;
		--shadow-sm: 0 1px 2px rgba(23, 37, 84, 0.06);
		--shadow-md: 0 6px 20px rgba(23, 37, 84, 0.08);
		--maxw: 760px;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
	}

	body {
		font-family:
			-apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans",
			"Hiragino Kaku Gothic ProN", "Noto Sans JP", Meiryo, sans-serif;
		line-height: 1.8;
		color: var(--color-text);
		background:
			radial-gradient(
					1200px 400px at 100% -10%,
					var(--color-primary-light),
					transparent 60%
				)
			no-repeat,
			var(--color-bg);
		-webkit-font-smoothing: antialiased;
	}

	main {
		max-width: var(--maxw);
		margin: 0 auto;
		padding: 3rem 1.25rem;
		min-height: 60vh;
	}

	main.wide {
		max-width: 1040px;
	}

	h1,
	h2,
	h3,
	h4 {
		color: var(--color-heading);
		line-height: 1.4;
		font-weight: 700;
	}

	h1 {
		font-size: 2rem;
		letter-spacing: -0.01em;
	}

	h2 {
		font-size: 1.45rem;
		margin-top: 2.5rem;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid var(--color-primary-light);
	}

	h3 {
		font-size: 1.15rem;
		margin-top: 1.8rem;
	}

	a {
		color: var(--color-primary-dark);
		text-decoration-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
		text-underline-offset: 2px;
	}

	a:hover {
		color: var(--color-primary);
	}

	p {
		margin: 1rem 0;
	}

	/* インラインコード */
	:not(pre) > code {
		background: var(--color-primary-light);
		color: var(--color-primary-dark);
		padding: 0.15em 0.4em;
		border-radius: 6px;
		font-size: 0.88em;
	}

	/* コードブロック */
	pre {
		padding: 1.1rem 1.25rem;
		border-radius: var(--radius);
		overflow-x: auto;
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	/* テーブル */
	table {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.95rem;
	}

	th,
	td {
		text-align: left;
		padding: 0.6rem 0.85rem;
		border: 1px solid var(--color-border);
	}

	thead th {
		background: var(--color-primary-light);
		color: var(--color-heading);
	}

	tbody tr:nth-child(even) {
		background: var(--color-bg-subtle);
	}

	/* 引用 */
	blockquote {
		margin: 1.5rem 0;
		padding: 0.8rem 1.2rem;
		border-left: 4px solid var(--color-accent);
		background: var(--color-bg-subtle);
		border-radius: 0 var(--radius) var(--radius) 0;
		color: var(--color-text-muted);
	}

	blockquote p {
		margin: 0.4rem 0;
	}

	hr {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 2.5rem 0;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	/* Mermaidで生成されるSVGを中央寄せ */
	svg[id^="mermaid"],
	.mermaid svg {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 1.5rem auto;
	}
</style>
