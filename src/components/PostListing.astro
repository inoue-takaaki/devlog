---
import PostCard from "./PostCard.astro";
import Sidebar from "./Sidebar.astro";
import Pagination from "./Pagination.astro";
import type { Post, TagCount } from "../utils/blog";

interface Props {
  posts: Post[];
  eyebrow: string;
  heading: string;
  lead: string;
  years: { year: number; count: number }[];
  tags: TagCount[];
  total: number;
  activeYear?: number;
  activeTag?: string;
  currentPage: number;
  lastPage: number;
  prevUrl?: string;
  nextUrl?: string;
  paginationBase: string;
}

const {
  posts,
  eyebrow,
  heading,
  lead,
  years,
  tags,
  total,
  activeYear,
  activeTag,
  currentPage,
  lastPage,
  prevUrl,
  nextUrl,
  paginationBase,
} = Astro.props;
---

<div class="listing">
  <div class="content">
    <header class="hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="lead">{lead}</p>
    </header>

    <div class="toolbar">
      <span class="result-count">{total}件中 {posts.length}件を表示</span>
      <button type="button" class="sort-toggle" data-order="desc">
        <span class="sort-label">新しい順</span>
        <span class="sort-icon" aria-hidden="true">↓</span>
      </button>
    </div>

    <ul class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </ul>

    <Pagination
      currentPage={currentPage}
      lastPage={lastPage}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      base={paginationBase}
    />
  </div>

  <Sidebar years={years} activeYear={activeYear} tags={tags} activeTag={activeTag} />
</div>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".sort-toggle");
  const list = document.querySelector<HTMLUListElement>(".post-list");
  const label = btn?.querySelector(".sort-label");
  const icon = btn?.querySelector(".sort-icon");

  btn?.addEventListener("click", () => {
    if (!list) return;
    const asc = btn.dataset.order === "desc" ? true : false;
    btn.dataset.order = asc ? "asc" : "desc";
    if (label) label.textContent = asc ? "古い順" : "新しい順";
    if (icon) icon.textContent = asc ? "↑" : "↓";

    const items = Array.from(list.children) as HTMLElement[];
    items
      .sort((a, b) => {
        const ta = Number(a.dataset.ts);
        const tb = Number(b.dataset.ts);
        return asc ? ta - tb : tb - ta;
      })
      .forEach((el) => list.appendChild(el));
  });
</script>

<style>
  .listing {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 2.5rem;
    align-items: start;
  }
  .hero {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }
  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-primary);
  }
  .hero h1 {
    margin: 0 0 0.6rem;
    font-size: 2.2rem;
  }
  .lead {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.02rem;
  }
  .toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .result-count {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .sort-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .sort-toggle:hover {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }

  @media (max-width: 720px) {
    .listing {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    /* サイドバーを記事一覧の上に */
    .listing :global(.sidebar) {
      order: -1;
    }
  }
</style>
