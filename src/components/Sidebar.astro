---
import type { TagCount } from "../utils/blog";

interface Props {
  years: { year: number; count: number }[];
  activeYear?: number;
  tags: TagCount[];
  activeTag?: string;
}

const { years, activeYear, tags, activeTag } = Astro.props;
// 「すべて」に出す総件数は年集計の合計（現在の絞り込みに依らず常に全記事数）
const grandTotal = years.reduce((sum, y) => sum + y.count, 0);
const noFilter = activeYear == null && activeTag == null;
---

<aside class="sidebar">
  {tags.length > 0 && (
    <section class="filter-group">
      <h3>タグで絞り込み</h3>
      <ul>
        {tags.map(({ slug, label, count }) => (
          <li>
            <a
              href={`/blog/tag/${slug}`}
              class:list={["filter-link", { active: activeTag === slug }]}
            >
              <span>{label}</span>
              <span class="count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="filter-group">
    <h3>年で絞り込み</h3>
    <ul>
      <li>
        <a href="/" class:list={["filter-link", { active: noFilter }]}>
          <span>すべて</span>
          <span class="count">{grandTotal}</span>
        </a>
      </li>
      {years.map(({ year, count }) => (
        <li>
          <a
            href={`/blog/year/${year}`}
            class:list={["filter-link", { active: activeYear === year }]}
          >
            <span>{year}年</span>
            <span class="count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</aside>

<style>
  .filter-group + .filter-group {
    margin-top: 1.5rem;
  }
  .sidebar h3 {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }
  .filter-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.92rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .filter-link:hover {
    background: var(--color-bg-subtle);
    color: var(--color-primary-dark);
  }
  .filter-link.active {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    font-weight: 700;
  }
  .filter-link span:first-child {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .count {
    flex-shrink: 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    background: var(--color-bg-subtle);
    border-radius: 999px;
    padding: 0.05rem 0.55rem;
    min-width: 1.6rem;
    text-align: center;
  }
  .filter-link.active .count {
    background: #fff;
    color: var(--color-primary-dark);
  }
</style>
