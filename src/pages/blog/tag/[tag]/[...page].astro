---
import type { GetStaticPaths, Page } from "astro";
import Layout from "../../../../layouts/Layout.astro";
import PostListing from "../../../../components/PostListing.astro";
import {
  getSortedPosts,
  getYears,
  getTags,
  getPostsByTag,
  PAGE_SIZE,
  type Post,
} from "../../../../utils/blog";
import { getTagLabel } from "../../../../data/tags";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  const tags = getTags(posts);

  return tags.flatMap(({ slug }) => {
    const tagPosts = getPostsByTag(posts, slug);
    return paginate(tagPosts, {
      params: { tag: slug },
      pageSize: PAGE_SIZE,
    });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<Post> };
const activeTag = Astro.params.tag!;
const label = getTagLabel(activeTag);

const allPosts = await getSortedPosts();
const years = getYears(allPosts);
const tags = getTags(allPosts);
---

<Layout
  title={`${label}の記事 | Side Quest`}
  description={`「${label}」タグが付いた記事の一覧`}
  wide
>
  <PostListing
    posts={page.data}
    eyebrow="TAG"
    heading={label}
    lead={`「${label}」タグが付いた記事の一覧です。`}
    years={years}
    tags={tags}
    activeTag={activeTag}
    total={page.total}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    paginationBase={`/blog/tag/${activeTag}`}
  />
</Layout>
