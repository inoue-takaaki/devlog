# このファイルを terraform.tfvars にコピーして値を調整する（terraform.tfvars は .gitignore 済み）。
# 既定値のままでよければ tfvars は無くても apply できる。

# ローカルの個人用 AWS プロファイル名（`aws configure --profile <名前>` で作ったもの）
aws_profile = "personal"

# S3 バケットを作るリージョン
aws_region = "ap-northeast-1"

# OIDC でデプロイを許可する GitHub リポジトリ
github_repo = "inoue-takaaki/devlog"
